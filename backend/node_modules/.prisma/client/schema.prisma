generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  firstName        String
  lastName         String
  role             String         @default("VIEWER")
  avatar           String?
  phone            String?
  department       String?
  isActive         Boolean        @default(true)
  twoFactorEnabled Boolean        @default(false)
  lastLogin        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  auditLogs        AuditLog[]
  notifications    Notification[]
  salesOrders      SalesOrder[]   @relation("SalesOrderCreator")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                  String           @id @default(uuid())
  sku                 String           @unique
  name                String
  description         String?
  categoryId          String
  category            Category         @relation(fields: [categoryId], references: [id])
  imageUrl            String?
  barcode             String?
  qrCode              String?
  salesPrice          Decimal          @default(0)
  costPrice           Decimal          @default(0)
  procurementStrategy String           @default("MTS")
  reorderPoint        Int              @default(10)
  reorderQty          Int              @default(50)
  isRawMaterial       Boolean          @default(false)
  isFinishedGood      Boolean          @default(true)
  isActive            Boolean          @default(true)
  inventory           Inventory[]
  salesItems          SalesItem[]
  purchaseItems       PurchaseItem[]
  bomAsFinished       BillOfMaterial[] @relation("FinishedProduct")
  bomComponents       BomComponent[]
  stockMovements      StockMovement[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model Warehouse {
  id        String      @id @default(uuid())
  name      String
  code      String      @unique
  address   String?
  city      String?
  capacity  Int         @default(1000)
  zones     String?
  isActive  Boolean     @default(true)
  inventory Inventory[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Inventory {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  onHandQty   Int       @default(0)
  reservedQty Int       @default(0)
  batchNumber String?
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model Customer {
  id          String       @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  gstNumber   String?
  creditLimit Decimal      @default(0)
  isActive    Boolean      @default(true)
  salesOrders SalesOrder[]
  payments    Payment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  gstNumber      String?
  rating         Float           @default(4.0)
  leadTimeDays   Int             @default(7)
  isActive       Boolean         @default(true)
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model SalesOrder {
  id                 String      @id @default(uuid())
  orderNumber        String      @unique
  customerId         String
  customer           Customer    @relation(fields: [customerId], references: [id])
  status             String      @default("DRAFT")
  orderDate          DateTime    @default(now())
  deliveryDate       DateTime?
  subtotal           Decimal     @default(0)
  taxAmount          Decimal     @default(0)
  totalAmount        Decimal     @default(0)
  notes              String?
  items              SalesItem[]
  deliveries         Delivery[]
  invoices           Invoice[]
  payments           Payment[]
  createdById        String?
  createdBy          User?       @relation("SalesOrderCreator", fields: [createdById], references: [id])
  blockchainTxHash   String?
  blockchainBlock    Int?
  blockchainVerified Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model SalesItem {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal
  deliveredQty Int        @default(0)
  totalPrice   Decimal
}

model PurchaseOrder {
  id                 String         @id @default(uuid())
  orderNumber        String         @unique
  vendorId           String
  vendor             Vendor         @relation(fields: [vendorId], references: [id])
  status             String         @default("DRAFT")
  orderDate          DateTime       @default(now())
  expectedDate       DateTime?
  subtotal           Decimal        @default(0)
  taxAmount          Decimal        @default(0)
  totalAmount        Decimal        @default(0)
  notes              String?
  items              PurchaseItem[]
  blockchainTxHash   String?
  blockchainBlock    Int?
  blockchainVerified Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model PurchaseItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Decimal
  receivedQty     Int           @default(0)
  totalPrice      Decimal
}

model WorkCenter {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  type                String
  capacity            Int                  @default(100)
  utilization         Float                @default(0)
  isActive            Boolean              @default(true)
  manufacturingOrders ManufacturingOrder[]
  workOrders          WorkOrder[]
  bomOperations       BomOperation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model BillOfMaterial {
  id                  String               @id @default(uuid())
  name                String
  finishedProductId   String
  finishedProduct     Product              @relation("FinishedProduct", fields: [finishedProductId], references: [id])
  version             String               @default("1.0")
  productionDuration  Int                  @default(60)
  totalCost           Decimal              @default(0)
  isActive            Boolean              @default(true)
  components          BomComponent[]
  operations          BomOperation[]
  manufacturingOrders ManufacturingOrder[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model BomComponent {
  id        String         @id @default(uuid())
  bomId     String
  bom       BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  quantity  Int
  unit      String         @default("pcs")
}

model BomOperation {
  id           String         @id @default(uuid())
  bomId        String
  bom          BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  workCenterId String
  workCenter   WorkCenter     @relation(fields: [workCenterId], references: [id])
  sequence     Int
  name         String
  duration     Int
}

model ManufacturingOrder {
  id                 String         @id @default(uuid())
  orderNumber        String         @unique
  bomId              String
  bom                BillOfMaterial @relation(fields: [bomId], references: [id])
  workCenterId       String?
  workCenter         WorkCenter?    @relation(fields: [workCenterId], references: [id])
  quantity           Int
  producedQty        Int            @default(0)
  status             String         @default("DRAFT")
  scheduledDate      DateTime?
  completedDate      DateTime?
  workOrders         WorkOrder[]
  blockchainTxHash   String?
  blockchainBlock    Int?
  blockchainVerified Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model WorkOrder {
  id                   String             @id @default(uuid())
  orderNumber          String             @unique
  manufacturingOrderId String
  manufacturingOrder   ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  workCenterId         String
  workCenter           WorkCenter         @relation(fields: [workCenterId], references: [id])
  status               String             @default("PENDING")
  operatorName         String?
  startTime            DateTime?
  endTime              DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model StockMovement {
  id                 String   @id @default(uuid())
  productId          String
  product            Product  @relation(fields: [productId], references: [id])
  warehouseId        String?
  movementType       String
  quantity           Int
  previousQty        Int
  newQty             Int
  referenceType      String?
  referenceId        String?
  notes              String?
  blockchainTxHash   String?
  blockchainBlock    Int?
  blockchainVerified Boolean  @default(false)
  verified           Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model Delivery {
  id             String     @id @default(uuid())
  deliveryNumber String     @unique
  salesOrderId   String
  salesOrder     SalesOrder @relation(fields: [salesOrderId], references: [id])
  status         String     @default("SCHEDULED")
  scheduledDate  DateTime?
  deliveredDate  DateTime?
  trackingNumber String?
  driverName     String?
  blockchainHash String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Invoice {
  id            String     @id @default(uuid())
  invoiceNumber String     @unique
  salesOrderId  String
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  subtotal      Decimal
  taxAmount     Decimal
  totalAmount   Decimal
  status        String     @default("PENDING")
  dueDate       DateTime?
  paidDate      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Payment {
  id            String      @id @default(uuid())
  paymentNumber String      @unique
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  salesOrderId  String?
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])
  amount        Decimal
  method        String      @default("BANK_TRANSFER")
  status        String      @default("COMPLETED")
  reference     String?
  createdAt     DateTime    @default(now())
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  action         String
  entityType     String
  entityId       String?
  previousValue  String?
  newValue       String?
  ipAddress      String?
  blockchainHash String?
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model BlockchainLog {
  id          String   @id @default(uuid())
  txHash      String   @unique
  blockNumber Int?
  eventType   String
  entityType  String
  entityId    String
  dataHash    String
  status      String   @default("CONFIRMED")
  network     String   @default("polygon")
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  name        String
  type        String
  parameters  String?
  generatedBy String?
  fileUrl     String?
  summary     String?
  createdAt   DateTime @default(now())
}

model CompanySettings {
  id                String   @id @default(uuid())
  companyName       String   @default("Shiv Furniture Works")
  tagline           String   @default("Where Inventory Meets Intelligence")
  logo              String?
  address           String?
  phone             String?
  email             String?
  gstNumber         String?
  currency          String   @default("INR")
  timezone          String   @default("Asia/Kolkata")
  aiEnabled         Boolean  @default(true)
  blockchainEnabled Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}
