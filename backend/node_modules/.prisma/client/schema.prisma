generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES
  PURCHASE
  MANUFACTURING
  WAREHOUSE
  FINANCE
  VIEWER
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DELIVERED
  FULLY_DELIVERED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum ManufacturingStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorkOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProcurementStrategy {
  MTS
  MTO
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  RESERVATION
  RELEASE
  MANUFACTURING_CONSUME
  MANUFACTURING_PRODUCE
}

enum NotificationType {
  LOW_STOCK
  PROCUREMENT
  DELIVERY
  MANUFACTURING
  AI_INSIGHT
  BLOCKCHAIN
  SYSTEM
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  firstName        String
  lastName         String
  role             UserRole       @default(VIEWER)
  avatar           String?
  phone            String?
  isActive         Boolean        @default(true)
  twoFactorEnabled Boolean        @default(false)
  lastLogin        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  auditLogs        AuditLog[]
  notifications    Notification[]
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                  String              @id @default(uuid())
  sku                 String              @unique
  name                String
  description         String?
  categoryId          String
  category            Category            @relation(fields: [categoryId], references: [id])
  imageUrl            String?
  barcode             String?
  qrCode              String?
  salesPrice          Decimal             @default(0) @db.Decimal(12, 2)
  costPrice           Decimal             @default(0) @db.Decimal(12, 2)
  procurementStrategy ProcurementStrategy @default(MTS)
  reorderPoint        Int                 @default(10)
  reorderQty          Int                 @default(50)
  isRawMaterial       Boolean             @default(false)
  isFinishedGood      Boolean             @default(true)
  isActive            Boolean             @default(true)
  inventory           Inventory[]
  salesItems          SalesItem[]
  purchaseItems       PurchaseItem[]
  bomAsFinished       BillOfMaterial[]    @relation("FinishedProduct")
  bomComponents       BomComponent[]
  stockMovements      StockMovement[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Warehouse {
  id        String      @id @default(uuid())
  name      String
  code      String      @unique
  address   String?
  city      String?
  capacity  Int         @default(1000)
  zones     Json?
  isActive  Boolean     @default(true)
  inventory Inventory[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Inventory {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  onHandQty   Int       @default(0)
  reservedQty Int       @default(0)
  batchNumber String?
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model Customer {
  id          String       @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  gstNumber   String?
  creditLimit Decimal      @default(0) @db.Decimal(12, 2)
  isActive    Boolean      @default(true)
  salesOrders SalesOrder[]
  payments    Payment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  gstNumber      String?
  rating         Float           @default(4.0)
  leadTimeDays   Int             @default(7)
  isActive       Boolean         @default(true)
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model SalesOrder {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  status       OrderStatus @default(DRAFT)
  orderDate    DateTime    @default(now())
  deliveryDate DateTime?
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?
  items        SalesItem[]
  deliveries   Delivery[]
  invoices     Invoice[]
  payments     Payment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SalesItem {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  deliveredQty Int        @default(0)
  totalPrice   Decimal    @db.Decimal(12, 2)
}

model PurchaseOrder {
  id           String         @id @default(uuid())
  orderNumber  String         @unique
  vendorId     String
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  status       PurchaseStatus @default(DRAFT)
  orderDate    DateTime       @default(now())
  expectedDate DateTime?
  subtotal     Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal        @default(0) @db.Decimal(12, 2)
  notes        String?
  items        PurchaseItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model PurchaseItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)
  receivedQty     Int           @default(0)
  totalPrice      Decimal       @db.Decimal(12, 2)
}

model WorkCenter {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  type                String
  capacity            Int                  @default(100)
  utilization         Float                @default(0)
  isActive            Boolean              @default(true)
  manufacturingOrders ManufacturingOrder[]
  workOrders          WorkOrder[]
  bomOperations       BomOperation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model BillOfMaterial {
  id                  String               @id @default(uuid())
  name                String
  finishedProductId   String
  finishedProduct     Product              @relation("FinishedProduct", fields: [finishedProductId], references: [id])
  version             String               @default("1.0")
  productionDuration  Int                  @default(60)
  totalCost           Decimal              @default(0) @db.Decimal(12, 2)
  isActive            Boolean              @default(true)
  components          BomComponent[]
  operations          BomOperation[]
  manufacturingOrders ManufacturingOrder[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model BomComponent {
  id        String         @id @default(uuid())
  bomId     String
  bom       BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  quantity  Int
  unit      String         @default("pcs")
}

model BomOperation {
  id           String         @id @default(uuid())
  bomId        String
  bom          BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  workCenterId String
  workCenter   WorkCenter     @relation(fields: [workCenterId], references: [id])
  sequence     Int
  name         String
  duration     Int
}

model ManufacturingOrder {
  id            String              @id @default(uuid())
  orderNumber   String              @unique
  bomId         String
  bom           BillOfMaterial      @relation(fields: [bomId], references: [id])
  workCenterId  String?
  workCenter    WorkCenter?         @relation(fields: [workCenterId], references: [id])
  quantity      Int
  producedQty   Int                 @default(0)
  status        ManufacturingStatus @default(DRAFT)
  scheduledDate DateTime?
  completedDate DateTime?
  workOrders    WorkOrder[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model WorkOrder {
  id                   String             @id @default(uuid())
  orderNumber          String             @unique
  manufacturingOrderId String
  manufacturingOrder   ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  workCenterId         String
  workCenter           WorkCenter         @relation(fields: [workCenterId], references: [id])
  status               WorkOrderStatus    @default(PENDING)
  operatorName         String?
  startTime            DateTime?
  endTime              DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model StockMovement {
  id             String       @id @default(uuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  warehouseId    String?
  movementType   MovementType
  quantity       Int
  previousQty    Int
  newQty         Int
  referenceType  String?
  referenceId    String?
  notes          String?
  blockchainHash String?
  verified       Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Delivery {
  id             String     @id @default(uuid())
  deliveryNumber String     @unique
  salesOrderId   String
  salesOrder     SalesOrder @relation(fields: [salesOrderId], references: [id])
  status         String     @default("SCHEDULED")
  scheduledDate  DateTime?
  deliveredDate  DateTime?
  trackingNumber String?
  driverName     String?
  blockchainHash String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Invoice {
  id            String     @id @default(uuid())
  invoiceNumber String     @unique
  salesOrderId  String
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  subtotal      Decimal    @db.Decimal(12, 2)
  taxAmount     Decimal    @db.Decimal(12, 2)
  totalAmount   Decimal    @db.Decimal(12, 2)
  status        String     @default("PENDING")
  dueDate       DateTime?
  paidDate      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Payment {
  id            String      @id @default(uuid())
  paymentNumber String      @unique
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  salesOrderId  String?
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])
  amount        Decimal     @db.Decimal(12, 2)
  method        String      @default("BANK_TRANSFER")
  status        String      @default("COMPLETED")
  reference     String?
  createdAt     DateTime    @default(now())
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  action         String
  entityType     String
  entityId       String?
  previousValue  Json?
  newValue       Json?
  ipAddress      String?
  blockchainHash String?
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model BlockchainLog {
  id          String   @id @default(uuid())
  txHash      String   @unique
  blockNumber Int?
  eventType   String
  entityType  String
  entityId    String
  dataHash    String
  status      String   @default("CONFIRMED")
  network     String   @default("polygon")
  createdAt   DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

model Report {
  id          String   @id @default(uuid())
  name        String
  type        String
  parameters  Json?
  generatedBy String?
  fileUrl     String?
  summary     String?
  createdAt   DateTime @default(now())
}

model CompanySettings {
  id                String   @id @default(uuid())
  companyName       String   @default("Shiv Furniture Works")
  tagline           String   @default("Where Inventory Meets Intelligence")
  logo              String?
  address           String?
  phone             String?
  email             String?
  gstNumber         String?
  currency          String   @default("INR")
  timezone          String   @default("Asia/Kolkata")
  aiEnabled         Boolean  @default(true)
  blockchainEnabled Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}
